{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable"],
    "module": "nodenext",
    "target": "ESNext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": [
      "node",
      "vitest/importMeta",
    ],
    "rootDir": "./src",
    "outDir": "./dist/esm"
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*"],
}
